// =====================================================
// CODE ENCODE / DECODE
// =====================================================
function encodeScores(scores, personality){
  const data = {
    s: {
      c: scores.communication||0,
      e: scores.emotion||0,
      t: scores.trust||0,
      cf: scores.conflict||0,
      p: scores.partnership||0,
      i: scores.independence||0,
      f: scores.family||0
    },
    p: personality.key
  };
  try {
    const json = JSON.stringify(data);
    const b64 = btoa(unescape(encodeURIComponent(json)));
    // Take first 8 chars as display code, store full in session
    return b64;
  } catch(e){ return null; }
}

function decodeScores(b64){
  try {
    const json = decodeURIComponent(escape(atob(b64)));
    return JSON.parse(json);
  } catch(e){ return null; }
}

function generateShareCode(b64){
  // Short 6-char display code derived from b64
  const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
  let code = '';
  for(let i=0;i<6;i++){
    const idx = (b64.charCodeAt(i*3)||0) % chars.length;
    code += chars[idx];
  }
  return code;
}

// Store full encoded data in sessionStorage
function saveMyData(encoded){
  try { sessionStorage.setItem('myData', encoded); } catch(e){}
}
function loadMyData(){
