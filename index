// =====================================================
function loadCompatReport(){
  const myInput=document.getElementById('myCodeInput').value.trim();
  const partnerInput=document.getElementById('partnerCodeInput').value.trim();
  const errEl=document.getElementById('codeError');

  // Try to decode both
  const myData=decodeScores(myInput)||decodeScores(loadMyData());
  const partnerData=decodeScores(partnerInput);

  if(!myData||!partnerData){
    errEl.style.display='block';
    setTimeout(()=>errEl.style.display='none',3000);
    return;
  }

  errEl.style.display='none';
  buildCompatReport(myData, partnerData);
}

function buildCompatReport(myData, partnerData){
  const myP=personalities.find(p=>p.key===myData.p)||personalities[1];
  const ptP=personalities.find(p=>p.key===partnerData.p)||personalities[1];

  document.getElementById('compatIcon1').textContent=myP.icon;
  document.getElementById('compatName1').textContent=myP.name;
  document.getElementById('compatIcon2').textContent=ptP.icon;
  document.getElementById('compatName2').textContent=ptP.name;

  const container=document.getElementById('compatSections');
  container.innerHTML='';

  const axes=[
    {key:'c',  name:'التواصل العاطفي'},
    {key:'e',  name:'الذكاء العاطفي'},
    {key:'t',  name:'الثقة'},
    {key:'cf', name:'إدارة الخلاف'},
    {key:'p',  name:'الشراكة'},
    {key:'i',  name:'الاستقلالية'},
    {key:'f',  name:'القيم الأسرية'},
  ];

  // Compute compatibility per axis
  const strong=[], watch=[], neutral=[];
  axes.forEach(ax=>{
    const mv=myData.s[ax.key]||0;
    const pv=partnerData.s[ax.key]||0;
    const diff=Math.abs(mv-pv);
    const avg=(mv+pv)/2;
    if(diff<=2&&avg>=2) strong.push(ax);
    else if(diff>=4) watch.push(ax);
    else neutral.push(ax);
  });

  // Build bar chart section
  const barSection=document.createElement('div');
  barSection.className='compat-section';
  barSection.innerHTML=`<div class="compat-section-header"><div class="compat-section-icon">📊</div><div class="compat-section-title">مقارنة البصمتين</div></div>`;
  axes.forEach(ax=>{
    const mv=normalize(myData.s[ax.key]||0);
    const pv=normalize(partnerData.s[ax.key]||0);
    const row=document.createElement('div'); row.className='compat-axis-row';
    row.innerHTML=`
      <div class="compat-axis-name">${ax.name}</div>
      <div class="compat-bars">
        <div class="compat-bar-wrap"><div class="compat-bar-label" style="color:#7c5cbf">هو</div><div class="compat-bar-track"><div class="compat-bar-fill-h" data-w="${mv}"></div></div><div style="font-size:10px;color:var(--text-dim);width:28px;">${mv}%</div></div>
        <div class="compat-bar-wrap"><div class="compat-bar-label" style="color:#c9507a">هي</div><div class="compat-bar-track"><div class="compat-bar-fill-w" data-w="${pv}"></div></div><div style="font-size:10px;color:var(--text-dim);width:28px;">${pv}%</div></div>
      </div>`;
    barSection.appendChild(row);
  });
  container.appendChild(barSection);

  // Strong areas
  if(strong.length>0){
    const s=document.createElement('div'); s.className='compat-section';
    s.innerHTML=`<div class="compat-section-header"><div class="compat-section-icon">✅</div><div class="compat-section-title">مناطق القوة المشتركة</div><div class="compat-section-badge badge-strong">توافق عالٍ</div></div>`;
    strong.forEach(ax=>{
      const p=document.createElement('div');
      p.style.cssText='font-size:13px;margin-bottom:8px;padding-right:8px;border-right:2px solid var(--success);';
      p.textContent=`${ax.name} — كلاكما يتشابه في هذا المحور بشكل إيجابي`;
      s.appendChild(p);
    });
    s.appendChild(buildExercise(strong[0].key,'strong'));
    container.appendChild(s);
  }

  // Watch areas
  if(watch.length>0){
    const w=document.createElement('div'); w.className='compat-section';
    w.innerHTML=`<div class="compat-section-header"><div class="compat-section-icon">⚠️</div><div class="compat-section-title">مناطق تحتاج اتفاقاً مبكراً</div><div class="compat-section-badge badge-watch">اختلاف واضح</div></div>`;
    watch.forEach(ax=>{
      const p=document.createElement('div');
      p.style.cssText='font-size:13px;margin-bottom:8px;padding-right:8px;border-right:2px solid var(--danger);';
      p.textContent=`${ax.name} — هناك فارق ملحوظ بين أسلوبيكما في هذا المحور`;
      w.appendChild(p);
    });
    w.appendChild(buildExercise(watch[0].key,'watch'));
    container.appendChild(w);
  }

  // Neutral
  if(neutral.length>0){
    const n=document.createElement('div'); n.className='compat-section';
    n.innerHTML=`<div class="compat-section-header"><div class="compat-section-icon">💡</div><div class="compat-section-title">مناطق الإثراء المتبادل</div><div class="compat-section-badge badge-neutral">مكمّلان</div></div>`;
    neutral.forEach(ax=>{
      const p=document.createElement('div');
      p.style.cssText='font-size:13px;margin-bottom:8px;padding-right:8px;border-right:2px solid var(--gold);';
      p.textContent=`${ax.name} — اختلافكما هنا يمكن أن يكون مصدر إثراء لا توتر`;
      n.appendChild(p);
    });
    n.appendChild(buildExercise(neutral[0].key,'neutral'));
    container.appendChild(n);
  }

  showScreen('screen-compat');
  setTimeout(()=>{
    document.querySelectorAll('.compat-bar-fill-h,.compat-bar-fill-w').forEach(b=>b.style.width=b.dataset.w+'%');
  },300);
}

function normalize(v){ return Math.round(Math.max(0,Math.min(100,((v+6)/15)*100))); }

function buildExercise(axisKey, type){
  const exercises={
    c:{strong:"كل أسبوع: اجلسا 15 دقيقة بدون جوالات وتحدثا عن شيء واحد يشغل بالكما.",watch:"جربا تمرين الكرسيين: كل طرف يتكلم 3 دقائق دون مقاطعة — الآخر يستمع فقط.",neutral:"سؤال الأسبوع: ما الشيء الذي أتمنيت أن تخبرني به مؤخراً؟"},
    e:{strong:"شاركا يومياً: ما أفضل شيء وأصعب شيء في يومك؟",watch:"تمرين التسمية: حين تشعر بشيء صعب قل اسم الشعور بدلاً من التصرف بناءً عليه.",neutral:"تمرين المرآة: حين يتكلم شريكك أعد ما سمعته بكلماتك الخاصة."},
    t:{strong:"مراجعة مالية شهرية معاً — 30 دقيقة تتحدثان فيها عن الأرقام بشفافية.",watch:"ابدأ بجلسة واحدة: ضع كل أرقامك المالية على الطاولة وادعها تفعل الأمر ذاته.",neutral:"اتفقا على ميزانية مشتركة شهرية مع احتفاظ كل طرف بمبلغ شخصي."},
    cf:{strong:"ضعا قاعدة مشتركة للخلاف — مثلاً: لا نوم على خلاف.",watch:"تمرين التوقف: حين يرتفع الصوت كلاكما يأخذ 10 دقائق ثم يعودان.",neutral:"بعد كل خلاف: كل طرف يقول شيئاً واحداً فعله الآخر صح في الخلاف."},
    p:{strong:"قرارا مشتركا هذا الشهر: اختارا شيئاً يخص حياتكما معاً وقرراه معاً من البداية للنهاية.",watch:"قائمة القرارات: كل طرف يكتب ما يعتبره قراراً شخصياً وما يعتبره قراراً مشتركاً — قارنا القائمتين.",neutral:"قرارا كل أسبوع قراراً صغيراً بالتبادل — مرة هو مرة هي."},
    i:{strong:"كل طرف له وقت شخصي أسبوعي لا يُقاطع فيه.",watch:"اتفقا على تعريف واضح للمساحة الشخصية — ما هي وما حدودها.",neutral:"جربا نشاطاً مستقلاً لكل طرف ثم شاركا التجربة مع بعض."},
    f:{strong:"زيارة عائلية مشتركة شهرياً تخططان لها معاً.",watch:"حددا حدوداً واضحة للأسرة الممتدة — ما يدخل حياتكما وما لا يدخل.",neutral:"اتفقا على كيفية التعامل مع طلبات الأهل قبل أن تصل."},
  };
  const ex=exercises[axisKey];
  const text=ex?ex[type]:ex?ex.neutral:'تحدثا عن هذا المحور بصراحة في وقت هادئ.';
  const d=document.createElement('div'); d.className='exercise-card';
  d.innerHTML=`<div class="exercise-label">✦ تمرين عملي</div><div class="exercise-text">${text}</div>`;
  return d;
}

