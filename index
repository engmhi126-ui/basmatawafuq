function restartAssessment(){
  showScreen('screen-status');
  document.querySelectorAll('.status-card').forEach(c=>c.classList.remove('selected'));
  currentStatus=null;
  const btn=document.getElementById('continueBtn');
  btn.style.opacity='.4'; btn.style.pointerEvents='none';
}

// INIT
createParticles();

// Check URL for partner code
const urlParams=new URLSearchParams(window.location.search);
if(urlParams.get('code')){
  document.getElementById('partnerCodeInput').value=urlParams.get('code');
  showScreen('screen-partner-entry');
}
</script>
