  if((scores.emotion||0)>=4) ins.push({icon:"💛",title:"وعي عاطفي عالٍ",text:"تعرف ما تشعر به وتتعامل مع مشاعر شريكك باحترام."});
  else if((scores.emotion||0)<=-2) ins.push({icon:"🌊",title:"منطقة نمو: الذكاء العاطفي",text:"أحياناً تجد صعوبة في التعامل مع المشاعر — سواء مشاعرك أو مشاعر شريكك."});
  if((scores.partnership||0)>=4) ins.push({icon:"🤝",title:"شراكة حقيقية",text:"تؤمن أن الزواج فريق — قراراتك الكبيرة تُبنى مع شريكك لا فوقه."});
  else if((scores.independence||0)>=4&&(scores.partnership||0)<=0) ins.push({icon:"🦅",title:"استقلالية قوية",text:"تقدّر مساحتك الشخصية كثيراً — تأكد أن شريكك يشعر أنه شريك فعلي."});
  if((scores.trust||0)>=3) ins.push({icon:"🔓",title:"شفافية مرتفعة",text:"تميل للانفتاح المالي والشخصي — هذا يُسهل بناء الثقة العميقة."});
