function determinePersonality(scores){
  const map=[
    {key:"communication",type:"communicator"},{key:"partnership",type:"partner"},
    {key:"emotion",type:"expressor"},{key:"trust",type:"guardian"},
    {key:"family",type:"caregiver"},{key:"independence",type:"independent"},
    {key:"values",type:"grounded"},{key:"conflict",type:"analyst"}
  ];
  let top="partner",topS=-999;
  map.forEach(m=>{ const s=scores[m.key]||0; if(s>topS){topS=s;top=m.type;} });
  return personalities.find(p=>p.key===top)||personalities[1];
}

function generateInsights(scores){
  const ins=[];
  if((scores.communication||0)>=4) ins.push({icon:"💬",title:"تواصل قوي",text:"تُسمّي المشاعر والمواقف بجرأة — هذا يحمي العلاقة من التراكم الصامت."});
