<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>بصمة التوافق</title>
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&display=swap" rel="stylesheet">
<style>
:root {
  --deep:#1a1228; --purple:#2d1f4e; --violet:#4a2d8a;
  --gold:#c9a84c; --gold-light:#e8c97a; --cream:#f5f0e8;
  --white:#ffffff; --text-dim:#9b8fc0; --card-bg:#231840;
  --border:rgba(201,168,76,0.2); --success:#4ade80; --danger:#f87171;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Tajawal',sans-serif;background:var(--deep);color:var(--white);min-height:100vh;overflow-x:hidden;}
#particles{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:0;overflow:hidden;}
.particle{position:absolute;border-radius:50%;background:radial-gradient(circle,rgba(201,168,76,0.2),transparent);animation:float linear infinite;}
@keyframes float{0%{transform:translateY(100vh) scale(0);opacity:0;}10%{opacity:1;}90%{opacity:0.3;}100%{transform:translateY(-10vh) scale(1);opacity:0;}}
.screen{position:relative;z-index:1;min-height:100vh;display:none;flex-direction:column;align-items:center;justify-content:center;padding:28px 20px;}
.screen.active{display:flex;}

/* LANDING */
#screen-landing{text-align:center;background:radial-gradient(ellipse at 50% 0%,rgba(74,45,138,0.45) 0%,transparent 70%);}
.logo-mark{width:76px;height:76px;margin:0 auto 20px;position:relative;}
.logo-ring{width:76px;height:76px;border-radius:50%;border:2px solid var(--gold);position:absolute;animation:spin 8s linear infinite;}
.logo-ring::before{content:'';position:absolute;top:-4px;right:50%;width:8px;height:8px;border-radius:50%;background:var(--gold);}
.logo-inner{position:absolute;inset:12px;border-radius:50%;background:linear-gradient(135deg,var(--violet),var(--purple));display:flex;align-items:center;justify-content:center;font-size:20px;}
@keyframes spin{to{transform:rotate(360deg);}}
.brand-name{font-size:40px;font-weight:900;background:linear-gradient(135deg,var(--gold-light),var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;letter-spacing:-1px;margin-bottom:5px;}
.brand-sub{font-size:12px;color:var(--text-dim);letter-spacing:3px;margin-bottom:36px;}
.hero-headline{font-size:clamp(19px,5vw,28px);font-weight:700;line-height:1.6;margin-bottom:12px;max-width:460px;}
.hero-headline span{color:var(--gold-light);}
.hero-sub{font-size:14px;color:var(--text-dim);line-height:1.8;max-width:380px;margin-bottom:32px;}
.stats-row{display:flex;gap:24px;justify-content:center;margin-bottom:36px;flex-wrap:wrap;}
.stat{text-align:center;}
.stat-num{font-size:24px;font-weight:800;color:var(--gold);display:block;}
.stat-label{font-size:11px;color:var(--text-dim);margin-top:2px;}

/* BUTTONS */
.btn-primary{background:linear-gradient(135deg,var(--gold),var(--gold-light));color:var(--deep);border:none;padding:15px 36px;border-radius:50px;font-family:'Tajawal',sans-serif;font-size:16px;font-weight:700;cursor:pointer;transition:all .3s;box-shadow:0 8px 28px rgba(201,168,76,0.28);width:100%;max-width:300px;display:block;margin:0 auto;}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 12px 36px rgba(201,168,76,0.38);}
.btn-secondary{background:transparent;color:var(--text-dim);border:1px solid rgba(155,143,192,0.3);padding:11px 28px;border-radius:50px;font-family:'Tajawal',sans-serif;font-size:14px;cursor:pointer;transition:all .3s;margin-top:11px;display:block;margin-left:auto;margin-right:auto;}
.btn-secondary:hover{color:var(--white);border-color:var(--text-dim);}
.btn-outline{background:transparent;color:var(--gold);border:1.5px solid var(--gold);padding:13px 28px;border-radius:50px;font-family:'Tajawal',sans-serif;font-size:15px;font-weight:600;cursor:pointer;transition:all .3s;width:100%;max-width:300px;display:block;margin:0 auto;}
.btn-outline:hover{background:rgba(201,168,76,0.1);}
.disclaimer{font-size:11px;color:var(--text-dim);margin-top:18px;opacity:.7;max-width:280px;line-height:1.6;text-align:center;}

/* STATUS */
#screen-status{max-width:460px;margin:0 auto;}
.status-title{font-size:24px;font-weight:800;text-align:center;margin-bottom:7px;}
.status-sub{font-size:14px;color:var(--text-dim);text-align:center;margin-bottom:28px;line-height:1.7;}
.status-options{display:flex;flex-direction:column;gap:12px;width:100%;margin-bottom:24px;}
.status-card{background:var(--card-bg);border:2px solid rgba(201,168,76,0.13);border-radius:18px;padding:18px 20px;cursor:pointer;transition:all .3s;display:flex;align-items:center;gap:14px;}
.status-card:hover{border-color:var(--gold);background:rgba(74,45,138,0.4);transform:translateX(-3px);}
.status-card.selected{border-color:var(--gold);background:rgba(201,168,76,0.09);}
.status-card.disabled{opacity:.38;cursor:not-allowed;pointer-events:none;}
.status-icon{font-size:30px;flex-shrink:0;}
.status-name{font-size:16px;font-weight:700;margin-bottom:2px;}
.status-desc{font-size:12px;color:var(--text-dim);line-height:1.5;}
.status-badge{margin-right:auto;font-size:10px;font-weight:700;background:var(--gold);color:var(--deep);padding:3px 8px;border-radius:20px;letter-spacing:1px;white-space:nowrap;}
.coming-badge{margin-right:auto;font-size:10px;background:rgba(155,143,192,0.2);color:var(--text-dim);padding:3px 8px;border-radius:20px;white-space:nowrap;}

/* PARTNER CODE ENTRY */
#screen-partner-entry{max-width:440px;margin:0 auto;text-align:center;}
.entry-title{font-size:22px;font-weight:800;margin-bottom:8px;}
.entry-sub{font-size:14px;color:var(--text-dim);margin-bottom:28px;line-height:1.7;}
.code-input-wrap{margin:24px 0;}
.code-input{
  background:rgba(45,31,78,0.6);border:2px solid var(--border);border-radius:16px;
  padding:18px 20px;font-family:'Tajawal',sans-serif;font-size:26px;font-weight:800;
  color:var(--gold);text-align:center;letter-spacing:6px;width:100%;
  outline:none;transition:border .3s;direction:ltr;
}
.code-input:focus{border-color:var(--gold);}
.code-input::placeholder{color:rgba(201,168,76,0.3);letter-spacing:4px;font-size:20px;}
.code-error{color:var(--danger);font-size:13px;margin-top:8px;display:none;}

/* INTRO */
#screen-intro{max-width:480px;margin:0 auto;}
.intro-card{background:var(--card-bg);border:1px solid var(--border);border-radius:20px;padding:26px 22px;margin-bottom:14px;text-align:center;}
.intro-icon{font-size:42px;margin-bottom:12px;}
.intro-title{font-size:19px;font-weight:700;margin-bottom:9px;}
.intro-text{font-size:13px;color:var(--text-dim);line-height:1.8;}
.axes-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin:14px 0;}
.axis-chip{background:rgba(74,45,138,0.3);border:1px solid var(--border);border-radius:10px;padding:8px 11px;font-size:12px;color:var(--gold-light);text-align:center;}

/* STORY */
#screen-story{max-width:580px;margin:0 auto;width:100%;}
.progress-header{width:100%;display:flex;align-items:center;gap:13px;margin-bottom:22px;}
.progress-circle{position:relative;width:60px;height:60px;flex-shrink:0;}
.progress-circle svg{width:60px;height:60px;transform:rotate(-90deg);}
.progress-circle .track{fill:none;stroke:rgba(201,168,76,0.11);stroke-width:4;}
.progress-circle .fill{fill:none;stroke:var(--gold);stroke-width:4;stroke-linecap:round;stroke-dasharray:175.9;stroke-dashoffset:175.9;transition:stroke-dashoffset .8s cubic-bezier(.4,0,.2,1);}
.progress-num{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:var(--gold);}
.progress-info{flex:1;}
.progress-label{font-size:11px;color:var(--text-dim);margin-bottom:2px;}
.progress-axis{font-size:14px;font-weight:600;color:var(--gold-light);}
.story-card{background:linear-gradient(135deg,var(--card-bg),rgba(45,31,78,0.8));border:1px solid var(--border);border-radius:24px;padding:26px 22px;margin-bottom:18px;position:relative;overflow:hidden;transition:opacity .3s,transform .3s;}
.story-card::before{content:'';position:absolute;top:0;right:0;width:90px;height:90px;background:radial-gradient(circle,rgba(201,168,76,0.07),transparent);}
.story-context{font-size:12px;color:var(--text-dim);background:rgba(201,168,76,0.05);border-right:3px solid var(--gold);padding:9px 12px;border-radius:0 7px 7px 0;margin-bottom:16px;line-height:1.7;}
.story-situation{font-size:16px;font-weight:600;line-height:1.75;margin-bottom:5px;}
.story-question{font-size:14px;color:var(--gold-light);font-weight:500;margin-top:13px;}
.choices-list{display:flex;flex-direction:column;gap:10px;}
.choice-btn{background:rgba(45,31,78,0.5);border:1.5px solid rgba(201,168,76,0.12);border-radius:14px;padding:14px 16px;text-align:right;cursor:pointer;transition:all .3s;display:flex;align-items:flex-start;gap:12px;font-family:'Tajawal',sans-serif;width:100%;color:var(--white);}
.choice-btn:hover{border-color:var(--gold);background:rgba(74,45,138,0.4);transform:translateX(-3px);}
.choice-btn.selected{border-color:var(--gold);background:rgba(201,168,76,0.09);}
.choice-letter{width:28px;height:28px;border-radius:50%;background:rgba(201,168,76,0.12);border:1px solid rgba(201,168,76,0.28);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:var(--gold);flex-shrink:0;margin-top:2px;}
.choice-btn.selected .choice-letter{background:var(--gold);color:var(--deep);}
.choice-text{font-size:13px;line-height:1.6;text-align:right;}
.choice-insight{display:none;margin-top:8px;font-size:11px;color:var(--text-dim);background:rgba(0,0,0,0.2);border-radius:8px;padding:8px 10px;line-height:1.6;border-right:2px solid var(--gold);}
.choice-btn.selected .choice-insight{display:block;}
.deep-question{background:linear-gradient(135deg,rgba(74,45,138,0.22),rgba(26,18,40,0.5));border:1px solid rgba(201,168,76,0.16);border-radius:14px;padding:16px;margin-top:16px;display:none;}
.deep-question.visible{display:block;animation:fadeUp .5s ease;}
.deep-q-label{font-size:10px;color:var(--gold);letter-spacing:2px;margin-bottom:6px;}
.deep-q-text{font-size:13px;line-height:1.7;color:var(--cream);}
.next-btn{display:none;width:100%;background:linear-gradient(135deg,var(--gold),var(--gold-light));color:var(--deep);border:none;padding:14px;border-radius:14px;font-family:'Tajawal',sans-serif;font-size:15px;font-weight:700;cursor:pointer;transition:all .3s;margin-top:12px;}
.next-btn.visible{display:block;animation:fadeUp .5s ease;}
.next-btn:hover{transform:translateY(-2px);box-shadow:0 8px 22px rgba(201,168,76,0.28);}
@keyframes fadeUp{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);}}

/* MY RESULT */
#screen-result{max-width:580px;margin:0 auto;width:100%;padding-bottom:44px;}
.result-hero{text-align:center;padding:32px 16px 24px;}
.personality-badge{display:inline-flex;flex-direction:column;align-items:center;background:linear-gradient(135deg,var(--violet),var(--purple));border:2px solid var(--gold);border-radius:20px;padding:20px 28px;margin-bottom:20px;box-shadow:0 0 50px rgba(201,168,76,0.16);}
.badge-icon{font-size:44px;margin-bottom:6px;}
.badge-label{font-size:10px;color:var(--text-dim);letter-spacing:2px;}
.badge-name{font-size:24px;font-weight:800;color:var(--gold-light);margin-top:3px;}
.result-headline{font-size:19px;font-weight:700;margin-bottom:9px;}
.result-summary{font-size:13px;color:var(--text-dim);line-height:1.8;max-width:420px;margin:0 auto;}
.section-title{font-size:15px;font-weight:700;color:var(--gold-light);margin:22px 0 12px;border-right:3px solid var(--gold);padding-right:11px;}
.axes-result{display:flex;flex-direction:column;gap:11px;}
.axis-bar{background:var(--card-bg);border:1px solid var(--border);border-radius:13px;padding:13px 16px;}
.axis-bar-header{display:flex;justify-content:space-between;margin-bottom:8px;align-items:center;}
.axis-bar-name{font-size:13px;font-weight:600;}
.axis-bar-score{font-size:12px;color:var(--gold);font-weight:700;}
.axis-bar-track{height:5px;background:rgba(255,255,255,0.07);border-radius:4px;overflow:hidden;}
.axis-bar-fill{height:100%;background:linear-gradient(90deg,var(--violet),var(--gold));border-radius:4px;transition:width 1.2s cubic-bezier(.4,0,.2,1);width:0;}
.axis-bar-desc{font-size:11px;color:var(--text-dim);margin-top:6px;line-height:1.5;}
.insights-grid{display:flex;flex-direction:column;gap:10px;}
.insight-card{background:var(--card-bg);border:1px solid var(--border);border-radius:13px;padding:14px 16px;display:flex;gap:12px;align-items:flex-start;}
.insight-icon{font-size:20px;flex-shrink:0;margin-top:1px;}
.insight-title{font-size:13px;font-weight:700;margin-bottom:3px;}
.insight-text{font-size:12px;color:var(--text-dim);line-height:1.6;}

/* SHARE BOX */
.share-box{background:linear-gradient(135deg,rgba(74,45,138,0.35),var(--card-bg));border:1px solid var(--border);border-radius:20px;padding:24px;text-align:center;margin-top:20px;}
.share-box-title{font-size:18px;font-weight:700;margin-bottom:6px;color:var(--gold-light);}
.share-box-sub{font-size:13px;color:var(--text-dim);margin-bottom:16px;line-height:1.6;}
.code-display{background:rgba(0,0,0,0.32);border:2px dashed var(--gold);border-radius:13px;padding:16px;margin:14px 0;cursor:pointer;transition:all .3s;}
.code-display:hover{background:rgba(201,168,76,0.05);}
.code-display-label{font-size:10px;color:var(--text-dim);letter-spacing:2px;margin-bottom:6px;}
.code-display-value{font-size:28px;font-weight:800;color:var(--gold);letter-spacing:6px;direction:ltr;}
.code-display-hint{font-size:11px;color:var(--text-dim);margin-top:5px;}
.copied-toast{display:none;background:var(--success);color:var(--deep);padding:6px 16px;border-radius:50px;font-size:12px;font-weight:700;margin:0 auto 10px;width:fit-content;}
.copied-toast.visible{display:block;animation:fadeUp .3s ease;}
.whatsapp-btn{background:#25D366;color:#fff;border:none;padding:13px 28px;border-radius:50px;font-family:'Tajawal',sans-serif;font-size:15px;font-weight:700;cursor:pointer;transition:all .3s;width:100%;max-width:280px;display:block;margin:0 auto;}
.whatsapp-btn:hover{background:#1fb855;transform:translateY(-2px);}

/* COMPATIBILITY REPORT */
#screen-compat{max-width:580px;margin:0 auto;width:100%;padding-bottom:44px;}
.compat-hero{text-align:center;padding:28px 16px 20px;}
.compat-title{font-size:26px;font-weight:800;margin-bottom:8px;}
.compat-sub{font-size:14px;color:var(--text-dim);line-height:1.7;}
.couple-badges{display:flex;gap:12px;justify-content:center;margin:20px 0;flex-wrap:wrap;}
.couple-badge{background:var(--card-bg);border:1px solid var(--border);border-radius:16px;padding:14px 20px;text-align:center;flex:1;min-width:120px;}
.couple-badge-icon{font-size:28px;margin-bottom:4px;}
.couple-badge-role{font-size:10px;color:var(--text-dim);letter-spacing:1px;}
.couple-badge-name{font-size:15px;font-weight:700;color:var(--gold-light);}
.vs-divider{display:flex;align-items:center;font-size:18px;color:var(--text-dim);}

/* COMPAT SECTIONS */
.compat-section{background:var(--card-bg);border:1px solid var(--border);border-radius:16px;padding:18px 20px;margin-bottom:14px;}
.compat-section-header{display:flex;align-items:center;gap:10px;margin-bottom:14px;}
.compat-section-icon{font-size:22px;}
.compat-section-title{font-size:15px;font-weight:700;}
.compat-section-badge{margin-right:auto;font-size:11px;font-weight:700;padding:3px 10px;border-radius:20px;}
.badge-strong{background:rgba(74,222,128,0.15);color:var(--success);}
.badge-watch{background:rgba(248,113,113,0.15);color:var(--danger);}
.badge-neutral{background:rgba(201,168,76,0.15);color:var(--gold);}

.compat-axis-row{display:flex;align-items:center;gap:10px;margin-bottom:10px;}
.compat-axis-name{font-size:12px;color:var(--text-dim);width:90px;flex-shrink:0;text-align:right;}
.compat-bars{flex:1;display:flex;flex-direction:column;gap:4px;}
.compat-bar-wrap{display:flex;align-items:center;gap:6px;}
.compat-bar-label{font-size:10px;color:var(--text-dim);width:20px;text-align:center;}
.compat-bar-track{flex:1;height:6px;background:rgba(255,255,255,0.07);border-radius:4px;overflow:hidden;}
.compat-bar-fill-h{height:100%;border-radius:4px;transition:width 1s ease;background:linear-gradient(90deg,var(--violet),#7c5cbf);}
.compat-bar-fill-w{height:100%;border-radius:4px;transition:width 1s ease;background:linear-gradient(90deg,#c9507a,#e87aa0);}

.exercise-card{background:linear-gradient(135deg,rgba(74,45,138,0.25),rgba(26,18,40,0.4));border:1px solid rgba(201,168,76,0.18);border-radius:13px;padding:14px 16px;margin-top:10px;}
.exercise-label{font-size:10px;color:var(--gold);letter-spacing:2px;margin-bottom:6px;}
.exercise-text{font-size:13px;line-height:1.7;color:var(--cream);}

.legal-note{font-size:10px;color:var(--text-dim);text-align:center;line-height:1.7;opacity:.6;max-width:360px;margin:20px auto 0;padding:0 14px;}

@media(max-width:480px){
  .brand-name{font-size:33px;}
  .hero-headline{font-size:18px;}
  .couple-badges{flex-direction:column;}
  .couple-badge{min-width:unset;}
}
</style>
</head>
<body>
<div id="particles"></div>

<!-- ======== LANDING ======== -->
<div id="screen-landing" class="screen active">
  <div class="logo-mark"><div class="logo-ring"></div><div class="logo-inner">🌿</div></div>
  <div class="brand-name">بصمة التوافق</div>
  <div class="brand-sub">HUMAN MINDPRINT</div>
  <div class="hero-headline">تعرّف على نفسك من خلال<br><span>القرارات</span>، لا الأسئلة</div>
  <div class="hero-sub">مواقف حقيقية من الحياة الزوجية تكشف أنماطك العميقة — كيف تُحب، كيف تختلف، كيف تقرر</div>
  <div class="stats-row">
    <div class="stat"><span class="stat-num">12</span><span class="stat-label">موقف حقيقي</span></div>
    <div class="stat"><span class="stat-num">8</span><span class="stat-label">محور زوجي</span></div>
    <div class="stat"><span class="stat-num">15</span><span class="stat-label">دقيقة فقط</span></div>
  </div>
  <button class="btn-primary" onclick="showScreen('screen-status')">ابدأ رحلة الاكتشاف ←</button>
  <button class="btn-outline" style="margin-top:12px;" onclick="showScreen('screen-partner-entry')">عندي كود شريكي — أريد التقرير المشترك</button>
  <div class="disclaimer">للاستبصار الذاتي فقط. لا تشخيص نفسي ولا حكم على الزواج.</div>
</div>

<!-- ======== STATUS ======== -->
<div id="screen-status" class="screen">
  <div style="width:100%;max-width:440px;">
    <div class="status-title">ما وضعك الحالي؟</div>
    <div class="status-sub">القصص ستتكيف معك تماماً</div>
    <div class="status-options">
      <div class="status-card" onclick="selectStatus('married',this)">
        <div class="status-icon">💍</div>
        <div>
          <div class="status-name">متزوج / متزوجة</div>
          <div class="status-desc">مواقف من داخل الحياة الزوجية الفعلية</div>
        </div>
        <div class="status-badge">متاح</div>
      </div>
      <div class="status-card disabled">
        <div class="status-icon">💛</div>
        <div>
          <div class="status-name">مخطوب / مخطوبة</div>
          <div class="status-desc">مواقف التوافق قبل الزواج</div>
        </div>
        <div class="coming-badge">قريباً</div>
      </div>
      <div class="status-card disabled">
        <div class="status-icon">🌱</div>
        <div>
          <div class="status-name">أعزب / عزباء</div>
          <div class="status-desc">معرفة الذات وجاهزية الزواج</div>
        </div>
        <div class="coming-badge">قريباً</div>
      </div>
    </div>
    <button class="btn-primary" id="continueBtn" onclick="goToIntro()" style="opacity:.4;pointer-events:none;">متابعة ←</button>
    <button class="btn-secondary" onclick="showScreen('screen-landing')">العودة</button>
  </div>
</div>

<!-- ======== PARTNER CODE ENTRY ======== -->
<div id="screen-partner-entry" class="screen">
  <div style="width:100%;max-width:420px;">
    <div class="entry-title">أدخل كود شريكك</div>
    <div class="entry-sub">
      أكمل اختبارك أولاً — ثم أدخل كود شريكك<br>
      لنُولّد لكما تقرير التوافق الكامل
    </div>

