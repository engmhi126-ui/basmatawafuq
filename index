function renderStory(){
  const s=currentStories[currentStory];
  const total=currentStories.length;
  const offset=175.9-(currentStory/total)*175.9;
  document.getElementById('progressFill').style.strokeDashoffset=offset;
  document.getElementById('progressNum').textContent=`${currentStory+1}/${total}`;
  document.getElementById('currentAxis').textContent=s.axis;
  document.getElementById('storyContext').textContent=s.context;
  document.getElementById('storySituation').textContent=s.situation;
  document.getElementById('storyQuestion').textContent=s.question;
  document.getElementById('deepQuestionText').textContent=s.deep;
  document.getElementById('deepQuestion').classList.remove('visible');
  document.getElementById('nextBtn').classList.remove('visible');
  const list=document.getElementById('choicesList'); list.innerHTML='';
  s.choices.forEach((ch,idx)=>{
    const btn=document.createElement('button'); btn.className='choice-btn';
    btn.innerHTML=`<div class="choice-letter">${ch.l}</div><div class="choice-text">${ch.t}<div class="choice-insight">${ch.i}</div></div>`;
    btn.onclick=()=>selectChoice(idx,btn);
    list.appendChild(btn);
  });
}

function selectChoice(idx,btn){
  document.querySelectorAll('.choice-btn').forEach(b=>b.classList.remove('selected'));
  btn.classList.add('selected');
  const ch=currentStories[currentStory].choices[idx];
  Object.entries(ch.s).forEach(([k,v])=>{ myScores[k]=(myScores[k]||0)+v; });
  setTimeout(()=>{
    document.getElementById('deepQuestion').classList.add('visible');
    document.getElementById('nextBtn').classList.add('visible');
  },350);
}

function nextStory(){
  currentStory++;
  if(currentStory>=currentStories.length){ showResults(); return; }
  const card=document.getElementById('storyCard');
  card.style.opacity='0'; card.style.transform='translateX(22px)';
  setTimeout(()=>{
    renderStory();
    card.style.transition='none'; card.style.opacity='0'; card.style.transform='translateX(-22px)';
    setTimeout(()=>{ card.style.transition='all .4s ease'; card.style.opacity='1'; card.style.transform='translateX(0)'; },40);
  },270);
}

